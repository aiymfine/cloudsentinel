{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "CloudSentinel Security & Application Monitoring Dashboard",
  "editable": true,
  "title": "CloudSentinel Dashboard",
  "uid": "cloudsentinel",
  "tags": ["cloud-sentinel", "security", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Authorization Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Failures",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(auth_failures_total[5m])",
          "legendFormat": "Auth Failures (5m)",
          "refId": "A"
        },
        {
          "expr": "increase(http_server_requests_seconds_count{status=~\"4..\"}[5m])",
          "legendFormat": "4xx Errors (5m)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Requests by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(http_server_requests_seconds_count{status=~\"2..\"}[5m])",
          "legendFormat": "2xx Success",
          "refId": "A"
        },
        {
          "expr": "increase(http_server_requests_seconds_count{status=~\"4..\"}[5m])",
          "legendFormat": "4xx Client Error",
          "refId": "B"
        },
        {
          "expr": "increase(http_server_requests_seconds_count{status=~\"5..\"}[5m])",
          "legendFormat": "5xx Server Error",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p95 latency",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM Heap Memory",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 400 }
            ]
          },
          "unit": "mb"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1024 / 1024",
          "legendFormat": "Heap Used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "S3 Operations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(http_server_requests_seconds_count{uri=~\"/api/documents.*\",method=\"POST\"}[1h])",
          "legendFormat": "Uploads (1h)",
          "refId": "A"
        },
        {
          "expr": "increase(http_server_requests_seconds_count{uri=~\"/api/documents.*\",method=\"GET\"}[1h])",
          "legendFormat": "Downloads (1h)",
          "refId": "B"
        },
        {
          "expr": "increase(http_server_requests_seconds_count{uri=~\"/api/documents.*\",method=\"DELETE\"}[1h])",
          "legendFormat": "Deletes (1h)",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "super-light-blue", "mode": "fixed" },
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[5m]))",
          "legendFormat": "Total Request Rate",
          "refId": "A"
        }
      ]
    }
  ]
}
